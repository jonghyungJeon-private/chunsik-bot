# ── Platform (Discord) ───────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Optional: restrict to a single guild during local dev
DISCORD_GUILD_ID=

# ── Local storage (SQLite) ───────────────────────────────────────────
CHUNSIK_DB_PATH=./data/chunsik.db

# ── Local vector store ───────────────────────────────────────────────
CHUNSIK_VECTOR_PATH=./data/vectors

# ── Workspace (local clone) ──────────────────────────────────────────
# Absolute path to the locally cloned project Chunsik may operate on.
CHUNSIK_WORKSPACE_ROOT=

# ── AI CLI providers (no API keys; CLIs must be installed & authed) ───
# Ollama is optional; if unavailable Chunsik falls back to Claude/Codex CLI.
OLLAMA_MODEL=llama3.1
# Override CLI binary paths if not on PATH:
CLAUDE_CLI_BIN=claude
CODEX_CLI_BIN=codex
OLLAMA_CLI_BIN=ollama
