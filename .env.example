# Copy this file to `.env.local` for local Runtime execution.
# Runtime automatically loads `.env.local`; `.env` is not loaded automatically.
# Existing shell/CI environment variables override `.env.local`.
# Never commit `.env.local` or secret values.

# ── Platform (Discord) ──────────────────────────────────────────────
# Required to start the Discord Runtime. Set the real token only in `.env.local`.
DISCORD_BOT_TOKEN=
# Optional: restrict to a single guild during local development.
DISCORD_GUILD_ID=

# ── Canonical GitHub App configuration ────────────────────────────
# Required together to identify the repository used by repository-hosting operations.
QUOKY_GITHUB_OWNER=
QUOKY_GITHUB_REPO=

# Production repository-hosting authentication uses a GitHub App.
QUOKY_GITHUB_APP_ID=
# Preferred: path to a local PEM file outside Git. Never commit the key file.
QUOKY_GITHUB_APP_PRIVATE_KEY_PATH=
# Alternative to PRIVATE_KEY_PATH; inline PEM is supported but not recommended.
# When both are set, QUOKY_GITHUB_APP_PRIVATE_KEY takes precedence.
# QUOKY_GITHUB_APP_PRIVATE_KEY=
# Optional: skips installation lookup through the configured owner/repository.
QUOKY_GITHUB_APP_INSTALLATION_ID=

# ── Runtime mode ──────────────────────────────────────────────────────
# Optional: dev | prod. Takes precedence over NODE_ENV.
QUOKY_RUNTIME_ENV=
# Fallback: NODE_ENV=production selects prod; all other values select dev.
NODE_ENV=

# ── Legacy GitHub fallback ────────────────────────────────────────
# QUOKY_GITHUB_OWNER/REPO take precedence over these legacy identity variables.
CHUNSIK_GITHUB_OWNER=
CHUNSIK_GITHUB_REPO=
# Legacy dev-only PAT fallback. Production repository hosting requires GitHub App auth.
CHUNSIK_GITHUB_TOKEN=

# ── Local storage (SQLite) ─────────────────────────────────────
CHUNSIK_DB_PATH=./data/chunsik.db

# ── Local vector store ───────────────────────────────────────────────
CHUNSIK_VECTOR_PATH=./data/vectors

# ── Workspace (local clone) ──────────────────────────────────────
# Optional. Defaults to the Runtime working directory when omitted.
# CHUNSIK_WORKSPACE_ROOT=

# ── AI CLI providers (no API keys; CLIs must be installed and authenticated) ──
# Keep these non-secret defaults non-empty because empty values disable config fallbacks.
CLAUDE_CLI_BIN=claude
# CODEX_CLI_BIN is read by configuration, but the Codex provider is not wired
# into the current Runtime composition.
CODEX_CLI_BIN=codex
# Ollama is optional and availability-gated at Runtime startup.
OLLAMA_CLI_BIN=ollama
OLLAMA_MODEL=llama3.1
